<!--
    Main keyboard view layout.

    Structure:
    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
    в”Ӯ  Candidate / toolbar bar (paste, space, etc.) в”Ӯ
    в”Ӯ  в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ  в”Ӯ
    в”Ӯ  в”Ӯ Q в”Ӯ W в”Ӯ E в”Ӯ R в”Ӯ T в”Ӯ Y в”Ӯ U в”Ӯ I в”Ӯ O в”Ӯ P в”Ӯ  в”Ӯ
    в”Ӯ  в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө  в”Ӯ
    в”Ӯ  в”Ӯ A в”Ӯ S в”Ӯ D в”Ӯ F в”Ӯ G в”Ӯ H в”Ӯ J в”Ӯ K в”Ӯ L в”Ӯ   в”Ӯ  в”Ӯ
    в”Ӯ  в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө  в”Ӯ
    в”Ӯ  в”ӮвҮ§  в”Ӯ Z в”Ӯ X в”Ӯ C в”Ӯ V в”Ӯ B в”Ӯ N в”Ӯ M в”Ӯ вҢ« в”Ӯ  в”Ӯ
    в”Ӯ  в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ  в”Ӯ
    в”Ӯ  [Ctrl] [Paste Rich] [  SPACE  ] [.] [Enter] в”Ӯ
    в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FF1C1C1E">

    <!-- Toolbar: paste button + utility actions -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingHorizontal="8dp"
        android:background="#FF2C2C2E">

        <ImageButton
            android:id="@+id/btn_paste_rich"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_toolbar_bg"
            android:src="@android:drawable/ic_menu_edit"
            android:paddingHorizontal="12dp"
            android:contentDescription="Paste Rich Text"
            android:tooltipText="Paste Rich Text" />

        <ImageButton
            android:id="@+id/btn_paste_plain"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_toolbar_bg"
            android:src="@android:drawable/ic_menu_save"
            android:paddingHorizontal="12dp"
            android:contentDescription="Paste Plain Text"
            android:tooltipText="Paste Plain Text" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/btn_toolbar_bg"
            android:src="@android:drawable/ic_menu_preferences"
            android:paddingHorizontal="12dp"
            android:contentDescription="Settings"
            android:tooltipText="Settings" />
    </LinearLayout>

    <!-- Main keyboard area -->
    <FrameLayout
        android:id="@+id/keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
